<h1>Overview</h1>

<div class="stats">
  <div class="stat-card">
    <div class="stat-value">{{active_subscriptions}}</div>
    <div class="stat-label">Active Subscriptions</div>
  </div>
  <div class="stat-card">
    <div class="stat-value">{{events_last_24h}}</div>
    <div class="stat-label">Events (last 24h)</div>
  </div>
  <div class="stat-card">
    <div class="stat-value">{{pending_deliveries}}</div>
    <div class="stat-label">Pending Deliveries</div>
  </div>
  <div class="stat-card stat-card--warn">
    <div class="stat-value">{{exhausted_deliveries}}</div>
    <div class="stat-label">Exhausted Deliveries</div>
  </div>
</div>

<div class="test-panel">
  <h2>Send Test Event</h2>
  <p class="test-panel__hint">Fires an event and fans it out to all matching subscriptions. <a href="/dashboard/echo">View echo log →</a></p>
  <form method="POST" action="/dashboard/send-test-event" class="test-form">
    <div class="test-form__row">
      <label>
        Event Type
        <input type="text" name="event_type" value="test.event" placeholder="order.created">
      </label>
      <label class="test-form__payload">
        Payload (JSON)
        <textarea name="payload" rows="3">{"hello": "world"}</textarea>
      </label>
      <button type="submit" class="btn-send">Send →</button>
    </div>
  </form>
</div>

<h2>Recent Events</h2>
{{#if recent_events.length}}
<table>
  <thead>
    <tr>
      <th>ID</th>
      <th>Type</th>
      <th>Ingested At</th>
    </tr>
  </thead>
  <tbody>
    {{#each recent_events}}
    <tr>
      <td><a href="/dashboard/events/{{id}}">{{short_id}}</a></td>
      <td><code>{{event_type}}</code></td>
      <td>{{ingested_at_fmt}}</td>
    </tr>
    {{/each}}
  </tbody>
</table>
{{else}}
<p class="empty">No events yet — send one above.</p>
{{/if}}
